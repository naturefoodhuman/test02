# 创建/修改该文件的LLM大模型：Claude Sonnet 4.5 (via Arena.ai Agent Mode)
# 创建时间（北京时间，精确到秒）：2026-06-10 23:03:36 CST
#
# ============================================================================
# FORGE Factory · 环境变量模板
# 用法（真机）：cp _infra/.env.example _infra/.env  然后填入真实值
#               并在启动 LiteLLM / Claude Code 前 `source _infra/.env` 或用 dotenv 加载。
# ⚠️ .env 已被 .gitignore 忽略，绝不要提交真实 Key。
# ============================================================================

# ─── GLM 云端模型（经 ModelScope 魔搭接入）──────────────────────────────────
# 这里填 ModelScope（魔搭社区 https://modelscope.cn）账号的 SDK Token，
# 不是智谱官网的 Key。对应 litellm-config.yaml 里的 model: openai/ZhipuAI/GLM-5
GLM_API_KEY="在此填入你的 ModelScope SDK Token"

# ─── LiteLLM 网关 ──────────────────────────────────────────────────────────
# Claude Code 会把 ANTHROPIC_BASE_URL 指向这里
LITELLM_PORT="4000"

# ─── Ollama 本地服务 ───────────────────────────────────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"

# ─── Claude Code 接入 LiteLLM（关键）──────────────────────────────────────
# 让 Claude Code 走本地网关而非直连 Anthropic（C6：Claude Code 是唯一底座）
# 在 shell 里 export 这两个变量后再启动 VS Code / Claude Code：
ANTHROPIC_BASE_URL="http://localhost:4000"
# Claude Code 需要一个非空 token，走 LiteLLM 时这个值用于 LiteLLM 鉴权（如未设主密钥可随意非空）
ANTHROPIC_AUTH_TOKEN="sk-forge-local-anytoken"

# ─── 国内网络镜像（按需）──────────────────────────────────────────────────
# uv / pip 使用国内源
UV_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
PIP_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
# HuggingFace 镜像
HF_ENDPOINT="https://hf-mirror.com"
